# Environment variables for Neo4j Agent Memory MCP Server
# Copy this file to env.yaml and fill in your values
#
# For local development, you can use this with docker-compose:
#   docker-compose --env-file env.yaml up
#
# For Cloud Run, create secrets in Secret Manager:
#   gcloud secrets create neo4j-uri --data-file=- <<< "bolt://your-neo4j-host:7687"
#   gcloud secrets create neo4j-user --data-file=- <<< "neo4j"
#   gcloud secrets create neo4j-password --data-file=- <<< "your-password"

# Neo4j Connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here
NEO4J_DATABASE=neo4j

# Server Configuration
PORT=8080
PYTHONUNBUFFERED=1

# Optional: Vertex AI Configuration (for embeddings)
# GOOGLE_CLOUD_PROJECT=your-project-id
# VERTEX_AI_LOCATION=us-central1

# Optional: OpenAI Configuration (for LLM extraction)
# OPENAI_API_KEY=sk-your-key-here

# Optional: Logging
# LOG_LEVEL=INFO
