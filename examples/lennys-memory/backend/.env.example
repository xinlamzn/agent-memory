# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# OpenAI Configuration
OPENAI_API_KEY=sk-...

# Entity Enrichment Configuration
# Automatically enrich entities with data from Wikipedia and Diffbot
ENRICHMENT_ENABLED=true
# Optional: Diffbot API key for richer entity data
# DIFFBOT_API_KEY=your-diffbot-api-key

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:3000
