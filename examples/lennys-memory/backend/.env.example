# Memory Store
MEMORY_STORE_ENDPOINT=https://localhost:9200
MEMORY_STORE_DATABASE=lennys-pods

# AWS Bedrock
AWS_REGION=us-west-2
AWS_PROFILE=default

# Entity Enrichment Configuration
# Automatically enrich entities with data from Wikipedia and Diffbot
ENRICHMENT_ENABLED=true
# Optional: Diffbot API key for richer entity data
# DIFFBOT_API_KEY=your-diffbot-api-key

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# Neo4j (optional fallback - only needed if using backend="neo4j")
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=password

# OpenAI (optional fallback - only needed if using OpenAI embeddings)
# OPENAI_API_KEY=sk-...
