# Neo4j Agent Memory - Example Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Neo4j Connection
# =============================================================================
# If NEO4J_URI is set, examples will use this Neo4j instance.
# If NEO4J_URI is NOT set, examples will auto-start Docker Neo4j.
#
# For Docker test container (auto-started by make commands):
#   NEO4J_URI=bolt://localhost:7687
#   NEO4J_PASSWORD=test-password
#
# For your own Neo4j instance:
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here

# =============================================================================
# OpenAI API (Required for OpenAI embeddings and LLM extraction)
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# =============================================================================
# Alternative: Anthropic API (if using Anthropic embeddings)
# =============================================================================
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# =============================================================================
# Embedding Configuration (Optional - defaults shown)
# =============================================================================
# NAM_EMBEDDING__PROVIDER=openai
# NAM_EMBEDDING__MODEL=text-embedding-3-small
# NAM_EMBEDDING__DIMENSIONS=1536

# For sentence-transformers (no API key needed):
# NAM_EMBEDDING__PROVIDER=sentence_transformers
# NAM_EMBEDDING__MODEL=all-MiniLM-L6-v2
# NAM_EMBEDDING__DIMENSIONS=384

# =============================================================================
# Extraction Configuration (Optional - defaults shown)
# =============================================================================
# NAM_EXTRACTION__EXTRACTOR_TYPE=PIPELINE
# NAM_EXTRACTION__ENABLE_SPACY=true
# NAM_EXTRACTION__ENABLE_GLINER=true
# NAM_EXTRACTION__ENABLE_LLM_FALLBACK=true
# NAM_EXTRACTION__LLM_MODEL=gpt-4o-mini
# NAM_EXTRACTION__MERGE_STRATEGY=confidence

# =============================================================================
# Entity Resolution Configuration (Optional - defaults shown)
# =============================================================================
# NAM_RESOLUTION__STRATEGY=composite
# NAM_RESOLUTION__FUZZY_THRESHOLD=0.85
# NAM_RESOLUTION__SEMANTIC_THRESHOLD=0.8
