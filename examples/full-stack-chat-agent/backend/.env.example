# Memory Store
MEMORY_STORE_ENDPOINT=https://localhost:9200

# AWS Bedrock
AWS_REGION=us-west-2
AWS_PROFILE=default

# Neo4j News Graph (can be same or different database)
NEWS_GRAPH_URI=bolt://newsgraph.graphstuff.com
NEWS_GRAPH_USERNAME=newsgraph
NEWS_GRAPH_PASSWORD=newsgraph
NEWS_GRAPH_DATABASE=neo4j

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# Neo4j (optional fallback - only needed if using backend="neo4j")
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=letmeinnow

# OpenAI (optional fallback - only needed if using OpenAI embeddings)
# OPENAI_API_KEY=sk-...
